PUT_ROOT / basename)\n","\n","    if \"datasets/\" in raw_text:\n","        dataset_slug = raw_text.split(\"datasets/\", 1)[1]\n","        parts = [part for part in dataset_slug.split(\"/\") if part]\n","        if parts:\n","            candidates.append(INPUT_ROOT / parts[-1])\n","\n","    if \"notebooks/\" in raw_text:\n","        notebook_slug = raw_text.split(\"notebooks/\", 1)[1]\n","        parts = [part for part in notebook_slug.split(\"/\") if part]\n","        if parts:\n","            candidates.append(INPUT_ROOT / parts[-1])\n","\n","    # de-duplicate while preserving order\n","    unique_candidates = []\n","    seen = set()\n","    for candidate in candidates:\n","        candidate = candidate.resolve() if candidate.exists() else Path(str(candidate))\n","        key = candidate.as_posix()\n","        if key not in seen:\n","            seen.add(key)\n","            unique_candidates.append(candidate)\n","\n","    for candidate in unique_candidates:\n","        if candidate.exists():\n","            return candidate.resolve()\n","\n","    checked = \"\\n\".join(f\"- {candidate.as_posix()}\" for candidate in unique_candidates)\n","    raise FileNotFoundError(\n","        f\"Input path could not be resolved for: {user_path}\\nChecked candidates:\\n{checked}\\n\\n\"\n","        \"Attach both Kaggle inputs first, then rerun this cell.\"\n","    )\n","\n","def find_dataset_root(search_root):\n","    search_root = Path(search_root).resolve()\n","    if search_root.is_file():\n","        search_root = search_root.parent\n","\n","    meta_candidates = sorted(search_root.rglob(\"metadata.csv\"))\n","    if not meta_candidates:\n","        raise FileNotFoundError(f\"metadata.csv was not found under {search_root.as_posix()}\")\n","\n","    def candidate_score(meta_path):\n","        parent = meta_path.parent\n","        score = 0\n","        if (parent / \"RECORDS\").exists():\n","            score += 10\n","        if (parent / \"metadata_dictionary.csv\").exists():\n","            score += 5\n","        score -= len(parent.parts)\n","        return score\n","\n","    best_meta = max(meta_candidates, key=candidate_score)\n","    return best_meta.parent.resolve(), best_meta.resolve()\n","\n","def infer_dataset_name(resolved_input, dataset_root):\n","    for candidate in [resolved_input.name, dataset_root.name]:\n","        cleaned = sanitize_name(candidate).lower()\n","        if cleaned:\n","            return cleaned\n","    return \"dataset\"\n","\n","def prepare_dataset_reference(user_path):\n","    resolved_input = resolve_input_candidate(user_path)\n","    dataset_root, metadata_path = find_dataset_root(resolved_input)\n","    dataset_name = infer_dataset_name(resolved_input, dataset_root)\n","    return {\n","        \"user_path\": str(user_path),\n","        \"resolved_input\": resolved_input,\n","        \"dataset_root\": dataset_root,\n","        \"metadata_path\": metadata_path,\n","        \"dataset_name\": dataset_name,\n","    }\n","\n","synthesis_ref = prepare_dataset_reference(TRAIN_SYNTHESIS_INPUT)\n","huca_ref = prepare_dataset_reference(TEST_HUCA_INPUT)\n","\n","reference_df = pd.DataFrame(\n","    [\n","        {\n","            \"role\": \"datasynthesisbrugada\",\n","            \"user_path\": synthesis_ref[\"user_path\"],\n","            \"resolved_input\": synthesis_ref[\"resolved_input\"].as_posix(),\n","            \"dataset_root\": synthesis_ref[\"dataset_root\"].as_posix(),\n","            \"metadata_path\": synthesis_ref[\"metadata_path\"].as_posix(),\n","            \"dataset_name\": synthesis_ref[\"dataset_name\"],\n","        },\n","        {\n","            \"role\": \"brugada-huca\",\n","            \"user_path\": huca_ref[\"user_path\"],\n","            \"resolved_input\": huca_ref[\"resolved_input\"].as_posix(),\n","            \"dataset_root\": huca_ref[\"dataset_root\"].as_posix(),\n","            \"metadata_path\": huca_ref[\"metadata_path\"].as_posix(),\n","            \"dataset_name\": huca_ref[\"dataset_name\"],\n","        },\n","    ]\n",")\n","\n","display(reference_df)"]},{"cell_type":"code","execution_count":3,"id":"60283e17","metadata":{"execution":{"iopub.execute_input":"2026-04-07T08:05:39.80768Z","iopub.status.busy":"2026-04-07T08:05:39.807466Z","iopub.status.idle":"2026-04-07T08:12:39.507462Z","shell.execute_reply":"2026-04-07T08:12:39.506807Z"},"papermill":{"duration":419.706857,"end_time":"2026-04-07T08:12:39.510866","exception":false,"start_time":"2026-04-07T08:05:39.804009","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["Dataset: datasynthesisbrugada\n","Patients: 6760\n","Class counts:\n","brugada\n","0    5478\n","1    1282\n","Name: count, dtype: int64\n","Metadata path: /kaggle/input/notebooks/izzarsulynashrudin/datasynthesisbrugada/brugada-huca-synthetic-gan/metadata.csv\n","Dataset root : /kaggle/input/notebooks/izzarsulynashrudin/datasynthesisbrugada/brugada-huca-synthetic-gan\n","\n","Saved feature cache for datasynthesisbrugada: /kaggle/working/external_compare/cache/features_datasynthesisbrugada_7a4e7b75eb62.csv\n","Dataset: brugada-huca\n","Patients: 356\n","Class counts:\n","brugada\n","0    287\n","1     69\n","Name: count, dtype: int64\n","Metadata path: /kaggle/input/datasets/izzarsulynashrudin/brugada-huca/metadata.csv\n","Dataset root : /kaggle/input/datasets/izzarsulynashrudin/brugada-huca\n","\n","Saved feature cache for brugada-huca: /kaggle/working/external_compare/cache/features_brugada-huca_4d2f55f2a535.csv\n"]},{"data":{"text/html":["<div>\n","<style scoped>\n","    .dataframe tbody tr th:only-of-type {\n","        vertical-align: middle;\n","    }\n","\n","    .dataframe tbody tr th {\n","        vertical-align: top;\n","    }\n","\n","    .dataframe thead th {\n","        text-align: right;\n","    }\n","</style>\n","<table border=\"1\" class=\"dataframe\">\n","  <thead>\n","    <tr style=\"text-align: right;\">\n","      <th></th>\n","      <th>dataset</th>\n","      <th>n_patients</th>\n","      <th>n_brugada</th>\n","      <th>n_normal</th>\n","      <th>n_features</th>\n","    </tr>\n","  </thead>\n","  <tbody>\n","    <tr>\n","      <th>0</th>\n","      <td>datasynthesisbrugada</td>\n","      <td>6760</td>\n","      <td>1282</td>\n","      <td>5478</td>\n","      <td>357</td>\n","    </tr>\n","    <tr>\n","      <th>1</th>\n","      <td>brugada-huca</td>\n","      <td>356</td>\n","      <td>69</td>\n","      <td>287</td>\n","      <td>357</td>\n","    </tr>\n","  </tbody>\n","</table>\n","</div>"],"text/plain":["                dataset  n_patients  n_brugada  n_normal  n_features\n","0  datasynthesisbrugada        6760       1282      5478         357\n","1          brugada-huca         356         69       287         357"]},"metadata":{},"output_type":"display_data"}],"source":["def standardize_lead_names(sig_names):\n","    mapping = {}\n","    for name in sig_names:\n","        normalized = (\n","            str(name)\n","            .strip()\n","            .replace(\"AVR\", \"aVR\")\n","            .replace(\"AVL\", \"aVL\")\n","            .replace(\"AVF\", \"aVF\")\n","        )\n","        mapping[name] = normalized\n","    return mapping\n","\n","def build_record_map(dataset_root):\n","    hea_files = list(Path(dataset_root).rglob(\"*.hea\"))\n","    record_map = {}\n","    for hea in hea_files:\n","        patient_key = Path(hea).stem\n","        record_map[str(patient_key)] = str(Path(hea).with_suffix(\"\"))\n","    if not record_map:\n","        raise RuntimeError(f\"No WFDB .hea files found under {Path(dataset_root).as_posix()}\")\n","    return record_map\n","\n","def load_metadata(dataset_ref, target_column=\"brugada\"):\n","    metadata = pd.read_csv(dataset_ref[\"metadata_path\"]).copy()\n","    required_columns = {\"patient_id\", target_column}\n","    missing = required_columns.difference(metadata.columns)\n","    if missing:\n","        raise ValueError(\n","            f\"{dataset_ref['dataset_name']} missing required columns: {sorted(missing)}\"\n","        )\n","\n","    metadata[\"patient_id\"] = pd.to_numeric(metadata[\"patient_id\"], errors=\"coerce\")\n","    metadata[target_column] = pd.to_numeric(metadata[target_column], errors=\"coerce\")\n","    metadata = metadata.dropna(subset=[\"patient_id\", target_column]).copy()\n","    metadata = metadata[metadata[target_column].isin([0, 1])].copy()\n","    metadata[\"patient_id\"] = metadata[\"patient_id\"].astype(int)\n","    metadata[target_column] = metadata[target_column].astype(int)\n","    metadata = metadata.drop_duplicates(subset=[\"patient_id\"]).reset_index(drop=True)\n","\n","    record_map = build_record_map(dataset_ref[\"dataset_root\"])\n","    available_ids = metadata[\"patient_id\"].astype(str).isin(record_map.keys())\n","    metadata = metadata.loc[available_ids].reset_index(drop=True)\n","\n","    if metadata.empty:\n","        raise RuntimeError(f\"{dataset_ref['dataset_name']} has no usable patients after filtering.\")\n","\n","    print(f\"Dataset: {dataset_ref['dataset_name']}\")\n","    print(\"Patients:\", len(metadata))\n","    print(\"Class counts:\")\n","    print(metadata[target_column].value_counts(dropna=False).sort_index())\n","    print(\"Metadata path:\", dataset_ref[\"metadata_path\"].as_posix())\n","    print(\"Dataset root :\", dataset_ref[\"dataset_root\"].as_posix())\n","    print()\n","\n","    return metadata, record_map\n","\n","def load_ecg_record(patient_id, record_map):\n","    patient_id = str(patient_id)\n","    if patient_id not in record_map:\n","        raise KeyError(f\"Record for patient_id {patient_id} not found.\")\n","\n","    record = wfdb.rdrecord(record_map[patient_id])\n","    signal_df = pd.DataFrame(record.p_signal, columns=record.sig_name)\n","    signal_df = signal_df.rename(columns=standardize_lead_names(signal_df.columns.tolist()))\n","\n","    for lead_name in STANDARD_LEADS:\n","        if lead_name not in signal_df.columns:\n","            raise ValueError(f\"Lead {lead_name} not found for patient_id {patient_id}\")\n","\n","    signal_df = signal_df[STANDARD_LEADS].copy()\n","    return signal_df.values.astype(np.float32), STANDARD_LEADS, int(record.fs)\n","\n","def bandpass_filter(x, fs, low=0.5, high=40.0, order=3):\n","    nyquist = 0.5 * fs\n","    low = max(low / nyquist, 1e-4)\n","    high = min(high / nyquist, 0.99)\n","    b, a = butter(order, [low, high], btype=\"band\")\n","    return filtfilt(b, a, x, axis=0)\n","\n","def robust_scale(x):\n","    median = np.median(x, axis=0, keepdims=True)\n","    mad = np.median(np.abs(x - median), axis=0, keepdims=True)\n","    mad = np.where(mad < 1e-6, 1.0, mad)\n","    return (x - median) / (1.4826 * mad)\n","\n","def detect_r_peaks(signal_1d, fs):\n","    signal = signal_1d.copy()\n","    if len(signal) >= 11:\n","        signal = savgol_filter(signal, 11, 3)\n","    signal = signal - np.median(signal)\n","\n","    prominence = max(0.15, np.std(signal) * 0.5)\n","    distance = int(0.45 * fs)\n","\n","    peaks, _ = find_peaks(signal, distance=distance, prominence=prominence)\n","    if len(peaks) == 0:\n","        peaks, _ = find_peaks(np.abs(signal), distance=distance, prominence=np.std(np.abs(signal)) * 0.3)\n","    return peaks\n","\n","def extract_median_beat(X, leads, fs):\n","    lead_priority = [\"II\", \"V2\", \"V1\", \"V3\", \"I\"]\n","    pre = int(0.25 * fs)\n","    post = int(0.45 * fs)\n","\n","    peaks = np.array([], dtype=int)\n","    for ref_lead in lead_priority:\n","        if ref_lead in leads:\n","            ref_index = leads.index(ref_lead)\n","            peaks = detect_r_peaks(X[:, ref_index], fs)\n","            peaks = peaks[(peaks > pre) & (peaks < len(X) - post)]\n","            if len(peaks) >= 2:\n","                break\n","\n","    beats = []\n","    for peak in peaks:\n","        beat = X[peak - pre : peak + post, :]\n","        if beat.shape[0] == pre + post:\n","            beats.append(beat)\n","\n","    if len(beats) == 0:\n","        center = len(X) // 2\n","        beat = X[max(0, center - pre) : min(len(X), center + post), :]\n","        padded = np.zeros((pre + post, X.shape[1]), dtype=np.float32)\n","        padded[: beat.shape[0], :] = beat\n","        return padded, pre\n","\n","    median_beat = np.median(np.stack(beats, axis=0), axis=0)\n","    return median_beat.astype(np.float32), pre\n","\n","def zero_crossings(x):\n","    return int(np.sum(np.diff(np.signbit(x)).astype(int)))\n","\n","def safe_slope(y):\n","    if len(y) < 2:\n","        return 0.0\n","    xs = np.arange(len(y))\n","    return float(np.polyfit(xs, y, 1)[0])\n","\n","def integrate_abs_area(x):\n","    trapezoid = getattr(np, \"trapezoid\", None)\n","    if trapezoid is not None:\n","        return float(trapezoid(np.abs(x)))\n","    return float(np.trapz(np.abs(x)))\n","\n","def extract_strip_features(x, prefix):\n","    return {\n","        f\"{prefix}_mean\": float(np.mean(x)),\n","        f\"{prefix}_std\": float(np.std(x)),\n","        f\"{prefix}_min\": float(np.min(x)),\n","        f\"{prefix}_max\": float(np.max(x)),\n","        f\"{prefix}_ptp\": float(np.ptp(x)),\n","        f\"{prefix}_median\": float(np.median(x)),\n","        f\"{prefix}_q05\": float(np.quantile(x, 0.05)),\n","        f\"{prefix}_q25\": float(np.quantile(x, 0.25)),\n","        f\"{prefix}_q75\": float(np.quantile(x, 0.75)),\n","        f\"{prefix}_q95\": float(np.quantile(x, 0.95)),\n","        f\"{prefix}_rms\": float(np.sqrt(np.mean(x**2))),\n","        f\"{prefix}_abs_area\": float(np.sum(np.abs(x))),\n","        f\"{prefix}_energy\": float(np.sum(x**2)),\n","        f\"{prefix}_skew\": float(skew(x)),\n","        f\"{prefix}_kurtosis\": float(kurtosis(x)),\n","        f\"{prefix}_zero_cross\": float(zero_crossings(x)),\n","    }\n","\n","def extract_beat_features(beat_1d, r_index, prefix):\n","    q_window = beat_1d[max(0, r_index - 8) : r_index]\n","    s_window = beat_1d[r_index : min(len(beat_1d), r_index + 12)]\n","    st_window = beat_1d[min(len(beat_1d), r_index + 6) : min(len(beat_1d), r_index + 16)]\n","    t_window = beat_1d[min(len(beat_1d), r_index + 18) : min(len(beat_1d), r_index + 35)]\n","    pre_window = beat_1d[max(0, r_index - 10) : max(1, r_index - 2)]\n","\n","    return {\n","        f\"{prefix}_beat_r_amp\": float(beat_1d[r_index]),\n","        f\"{prefix}_beat_q_min\": float(np.min(q_window)) if len(q_window) else 0.0,\n","        f\"{prefix}_beat_s_min\": float(np.min(s_window)) if len(s_window) else 0.0,\n","        f\"{prefix}_beat_qrs_range\": float(np.ptp(beat_1d[max(0, r_index - 6) : min(len(beat_1d), r_index + 10)])),\n","        f\"{prefix}_beat_st_mean\": float(np.mean(st_window)) if len(st_window) else 0.0,\n","        f\"{prefix}_beat_st_max\": float(np.max(st_window)) if len(st_window) else 0.0,\n","        f\"{prefix}_beat_st_slope\": float(safe_slope(st_window)) if len(st_window) else 0.0,\n","        f\"{prefix}_beat_t_max\": float(np.max(t_window)) if len(t_window) else 0.0,\n","        f\"{prefix}_beat_t_mean\": float(np.mean(t_window)) if len(t_window) else 0.0,\n","        f\"{prefix}_beat_pre_mean\": float(np.mean(pre_window)) if len(pre_window) else 0.0,\n","        f\"{prefix}_beat_area\": integrate_abs_area(beat_1d),\n","        f\"{prefix}_beat_energy\": float(np.sum(beat_1d**2)),\n","    }\n","\n","def build_feature_row(patient_id, record_map):\n","    X, leads, fs = load_ecg_record(patient_id, record_map)\n","    Xf = bandpass_filter(X, fs=fs, low=0.5, high=40.0, order=3)\n","    Xn = robust_scale(Xf)\n","    median_beat, r_index = extract_median_beat(Xn, leads, fs)\n","\n","    feature_map = {\n","        \"patient_id\": int(patient_id),\n","        \"fs\": int(fs),\n","        \"n_samples\": int(Xn.shape[0]),\n","    }\n","\n","    for lead_index, lead_name in enumerate(leads):\n","        feature_map.update(extract_strip_features(Xn[:, lead_index], prefix=f\"{lead_name}_strip\"))\n","\n","    for lead_index, lead_name in enumerate(leads):\n","        feature_map.update(extract_beat_features(median_beat[:, lead_index], r_index=r_index, prefix=f\"{lead_name}\"))\n","\n","    for lead_name in [\"V1\", \"V2\", \"V3\"]:\n","        lead_index = leads.index(lead_name)\n","        segment = median_beat[:, lead_index]\n","        feature_map[f\"{lead_name}_post_r_100ms_mean\"] = float(np.mean(segment[r_index + 5 : r_index + 15]))\n","        feature_map[f\"{lead_name}_post_r_150ms_mean\"] = float(np.mean(segment[r_index + 10 : r_index + 20]))\n","        feature_map[f\"{lead_name}_post_r_200ms_mean\"] = float(np.mean(segment[r_index + 15 : r_index + 25]))\n","\n","    feature_map[\"V1_V2_st_mean_avg\"] = float(np.mean([feature_map[\"V1_beat_st_mean\"], feature_map[\"V2_beat_st_mean\"]]))\n","    feature_map[\"V1_V3_st_mean_avg\"] = float(np.mean([feature_map[\"V1_beat_st_mean\"], feature_map[\"V3_beat_st_mean\"]]))\n","    feature_map[\"V1_V2_qrs_avg\"] = float(np.mean([feature_map[\"V1_beat_qrs_range\"], feature_map[\"V2_beat_qrs_range\"]]))\n","    feature_map[\"V1_V2_strip_energy_avg\"] = float(np.mean([feature_map[\"V1_strip_energy\"], feature_map[\"V2_strip_energy\"]]))\n","    feature_map[\"V1_minus_V2_st_mean\"] = float(feature_map[\"V1_beat_st_mean\"] - feature_map[\"V2_beat_st_mean\"])\n","    feature_map[\"V2_minus_V3_st_mean\"] = float(feature_map[\"V2_beat_st_mean\"] - feature_map[\"V3_beat_st_mean\"])\n","\n","    for lead_a, lead_b in [(\"V1\", \"V2\"), (\"V2\", \"V3\"), (\"I\", \"II\"), (\"II\", \"V1\")]:\n","        idx_a, idx_b = leads.index(lead_a), leads.index(lead_b)\n","        corr = np.corrcoef(Xn[:, idx_a], Xn[:, idx_b])[0, 1]\n","        feature_map[f\"corr_{lead_a}_{lead_b}\"] = float(np.nan_to_num(corr))\n","\n","    return feature_map\n","\n","def build_feature_table(dataset_ref, target_column=\"brugada\", use_cache=True):\n","    metadata, record_map = load_metadata(dataset_ref, target_column=target_column)\n","    cache_key = hashlib.md5(dataset_ref[\"dataset_root\"].as_posix().encode(\"utf-8\")).hexdigest()[:12]\n","    cache_file = CACHE_DIR / f\"features_{sanitize_name(dataset_ref['dataset_name'])}_{cache_key}.csv\"\n","\n","    if use_cache and cache_file.exists():\n","        features_df = pd.read_csv(cache_file)\n","        print(f\"Loaded cached features for {dataset_ref['dataset_name']}: {cache_file.as_posix()}\")\n","        return features_df\n","\n","    feature_rows = []\n","    for row in metadata.itertuples(index=False):\n","        patient_id = int(getattr(row, \"patient_id\"))\n","        try:\n","            feature_map = build_feature_row(patient_id, record_map)\n","            feature_map[\"target\"] = int(getattr(row, target_column))\n","            feature_rows.append(feature_map)\n","        except Exception as exc:\n","            print(f\"Skipping patient_id={patient_id} due to preprocessing error: {exc}\")\n","\n","    features_df = pd.DataFrame(feature_rows)\n","    if features_df.empty:\n","        raise RuntimeError(f\"No feature rows were produced for {dataset_ref['dataset_name']}.\")\n","\n","    features_df = features_df.drop_duplicates(subset=[\"patient_id\"]).reset_index(drop=True)\n","    features_df.to_csv(cache_file, index=False)\n","    print(f\"Saved feature cache for {dataset_ref['dataset_name']}: {cache_file.as_posix()}\")\n","    return features_df\n","\n","synthesis_features = build_feature_table(synthesis_ref)\n","huca_features = build_feature_table(huca_ref)\n","\n","dataset_overview_df = pd.DataFrame(\n","    [\n","        {\n","            \"dataset\": synthesis_ref[\"dataset_name\"],\n","            \"n_patients\": len(synthesis_features),\n","            \"n_brugada\": int((synthesis_features[\"target\"] == 1).sum()),\n","            \"n_normal\": int((synthesis_features[\"target\"] == 0).sum()),\n","            \"n_features\": synthesis_features.shape[1] - 2,\n","        },\n","        {\n","            \"dataset\": huca_ref[\"dataset_name\"],\n","            \"n_patients\": len(huca_features),\n","            \"n_brugada\": int((huca_features[\"target\"] == 1).sum()),\n","            \"n_normal\": int((huca_features[\"target\"] == 0).sum()),\n","            \"n_features\": huca_features.shape[1] - 2,\n","        },\n","    ]\n",")\n","display(dataset_overview_df)"]},{"cell_type":"code","execution_count":4,"id":"92bf684e","metadata":{"execution":{"iopub.execute_input":"2026-04-07T08:12:39.517426Z","iopub.status.busy":"2026-04-07T08:12:39.517165Z","iopub.status.idle":"2026-04-07T08:12:39.542727Z","shell.execute_reply":"2026-04-07T08:12:39.54205Z"},"papermill":{"duration":0.030599,"end_time":"2026-04-07T08:12:39.544049","exception":false,"start_time":"2026-04-07T08:12:39.51345","status":"completed"},"tags":[]},"outputs":[],"source":["def specificity_score(y_true, y_pred):\n","    matrix = confusion_matrix(y_true, y_pred, labels=[0, 1])\n","    tn, fp, fn, tp = matrix.ravel()\n","    return tn / (tn + fp) if (tn + fp) > 0 else 0.0\n","\n","def sensitivity_score(y_true, y_pred):\n","    matrix = confusion_matrix(y_true, y_pred, labels=[0, 1])\n","    tn, fp, fn, tp = matrix.ravel()\n","    return tp / (tp + fn) if (tp + fn) > 0 else 0.0\n","\n","def tune_threshold(y_true, y_prob):\n","    precision_values, recall_values, threshold_values = precision_recall_curve(y_true, y_prob)\n","    if len(threshold_values) == 0:\n","        default_threshold = 0.5\n","        default_f1 = f1_score(y_true, (y_prob >= default_threshold).astype(int))\n","        return float(default_threshold), float(default_f1)\n","\n","    precision_values = precision_values[:-1]\n","    recall_values = recall_values[:-1]\n","    f1_values = 2 * precision_values * recall_values / np.clip(precision_values + recall_values, 1e-8, None)\n","    best_index = int(np.nanargmax(f1_values))\n","    return float(threshold_values[best_index]), float(f1_values[best_index])\n","\n","def calculate_binary_metrics(y_true, y_prob, threshold):\n","    y_true = np.asarray(y_true).astype(int)\n","    y_prob = np.asarray(y_prob).astype(float)\n","    y_pred = (y_prob >= threshold).astype(int)\n","\n","    matrix = confusion_matrix(y_true, y_pred, labels=[0, 1])\n","    tn, fp, fn, tp = matrix.ravel()\n","\n","    return {\n","        \"Threshold\": float(threshold),\n","        \"AUC\": float(roc_auc_score(y_true, y_prob)) if len(np.unique(y_true)) > 1 else np.nan,\n","        \"PR AUC\": float(average_precision_score(y_true, y_prob)) if len(np.unique(y_true)) > 1 else np.nan,\n","        \"F1\": float(f1_score(y_true, y_pred)),\n","        \"Accuracy\": float(accuracy_score(y_true, y_pred)),\n","        \"Balanced Accuracy\": float(balanced_accuracy_score(y_true, y_pred)),\n","        \"Sensitivity\": float(tp / (tp + fn)) if (tp + fn) > 0 else 0.0,\n","        \"Specificity\": float(tn / (tn + fp)) if (tn + fp) > 0 else 0.0,\n","        \"Correctly Predicted\": int(np.sum(y_true == y_pred)),\n","        \"Total Samples\": int(len(y_true)),\n","        \"False Positives\": int(fp),\n","        \"False Negatives\": int(fn),\n","        \"True Positives\": int(tp),\n","        \"True Negatives\": int(tn),\n","    }, y_pred\n","\n","def get_feature_columns(df):\n","    return [column for column in df.columns if column not in [\"patient_id\", \"target\"]]\n","\n","def make_models(y_train):\n","    pos = int(np.sum(y_train == 1))\n","    neg = int(np.sum(y_train == 0))\n","    scale_pos_weight = neg / max(pos, 1)\n","\n","    models = {\n","        \"XGBoost Features\": XGBClassifier(\n","            n_estimators=500,\n","            max_depth=4,\n","            learning_rate=0.03,\n","            subsample=0.85,\n","            colsample_bytree=0.85,\n","            reg_alpha=0.3,\n","            reg_lambda=1.5,\n","            min_child_weight=2,\n","            objective=\"binary:logistic\",\n","            eval_metric=\"aucpr\",\n","            random_state=RANDOM_STATE,\n","            scale_pos_weight=scale_pos_weight,\n","            tree_method=\"hist\",\n","        ),\n","        \"Random Forest Features\": RandomForestClassifier(\n","            n_estimators=600,\n","            min_samples_leaf=2,\n","            class_weight=\"balanced_subsample\",\n","            random_state=RANDOM_STATE,\n","            n_jobs=-1,\n","        ),\n","        \"SVM RBF Features\": SVC(\n","            kernel=\"rbf\",\n","            C=2.0,\n","            gamma=\"scale\",\n","            probability=True,\n","            class_weight=\"balanced\",\n","            random_state=RANDOM_STATE,\n","        ),\n","        \"AdaBoost\": AdaBoostClassifier(\n","            n_estimators=350,\n","            learning_rate=0.05,\n","            random_state=RANDOM_STATE,\n","        ),\n","        \"Logistic Regression\": LogisticRegression(\n","            C=1.0,\n","            class_weight=\"balanced\",\n","            max_iter=3000,\n","            random_state=RANDOM_STATE,\n","        ),\n","    }\n","    return models\n","\n","def fit_preprocessors(train_df, feature_columns):\n","    imputer = SimpleImputer(strategy=\"median\")\n","    scaler = StandardScaler()\n","\n","    x_train = imputer.fit_transform(train_df[feature_columns])\n","    x_train_scaled = scaler.fit_transform(x_train)\n","    return imputer, scaler\n","\n","def transform_features(df, feature_columns, imputer, scaler):\n","    x = imputer.transform(df[feature_columns])\n","    x_scaled = scaler.transform(x)\n","    y = df[\"target\"].to_numpy(dtype=int)\n","    patient_ids = df[\"patient_id\"].tolist()\n","    return x, x_scaled, y, patient_ids\n","\n","def run_scenario(train_features_df, test_features_df, scenario_name, train_label, test_label):\n","    train_features_df = train_features_df.copy().reset_index(drop=True)\n","    test_features_df = test_features_df.copy().reset_index(drop=True)\n","\n","    feature_columns = sorted(set(get_feature_columns(train_features_df)).intersection(get_feature_columns(test_features_df)))\n","    if not feature_columns:\n","        raise RuntimeError(f\"No shared feature columns found for scenario: {scenario_name}\")\n","\n","    train_work_df = train_features_df[[\"patient_id\", \"target\"] + feature_columns].copy()\n","    test_work_df = test_features_df[[\"patient_id\", \"target\"] + feature_columns].copy()\n","\n","    print(\"=\" * 100)\n","    print(\"Scenario :\", scenario_name)\n","    print(\"Train on :\", train_label, \"| samples:\", len(train_work_df))\n","    print(\"Test on  :\", test_label, \"| samples:\", len(test_work_df))\n","    print(\"Shared features:\", len(feature_columns))\n","    print()\n","\n","    core_train_df, val_df = train_test_split(\n","        train_work_df,\n","        test_size=0.20,\n","        stratify=train_work_df[\"target\"],\n","        random_state=RANDOM_STATE,\n","    )\n","\n","    val_distribution = val_df[\"target\"].value_counts(dropna=False).sort_index().to_dict()\n","    print(\"Internal validation split for threshold tuning:\", len(val_df), val_distribution)\n","\n","    imputer_core, scaler_core = fit_preprocessors(core_train_df, feature_columns)\n","    x_core, x_core_scaled, y_core, _ = transform_features(core_train_df, feature_columns, imputer_core, scaler_core)\n","    x_val, x_val_scaled, y_val, val_ids = transform_features(val_df, feature_columns, imputer_core, scaler_core)\n","\n","    imputer_full, scaler_full = fit_preprocessors(train_work_df, feature_columns)\n","    x_full, x_full_scaled, y_full, full_ids = transform_features(train_work_df, feature_columns, imputer_full, scaler_full)\n","    x_test, x_test_scaled, y_test, test_ids = transform_features(test_work_df, feature_columns, imputer_full, scaler_full)\n","\n","    models = make_models(y_core)\n","    scenario_results = []\n","    scenario_predictions = {}\n","\n","    for model_name, model in models.items():\n","        print(f\"Training {model_name} ...\")\n","\n","        fit_x_core = x_core_scaled if (\"SVM\" in model_name or \"Logistic\" in model_name) e