","    \"peak_lead\": 1,            # lead II sebagai default\n","    \"min_peak_distance_sec\": 0.45,\n","\n","    # split rules\n","    \"synthetic_test_count\": 363,\n","    \"synthetic_dev_train_ratio\": 90,\n","    \"synthetic_dev_val_ratio\": 5,\n","    \"original_train_ratio\": 0.95,\n","    \"original_val_ratio\": 0.05,\n","}\n","CONFIG"]},{"cell_type":"markdown","id":"8512ec4a","metadata":{"papermill":{"duration":0.003879,"end_time":"2026-04-07T09:11:20.201968","exception":false,"start_time":"2026-04-07T09:11:20.198089","status":"completed"},"tags":[]},"source":["## 2. Helper: Label, Split, dan Loading Metadata"]},{"cell_type":"code","execution_count":5,"id":"95eaa369","metadata":{"execution":{"iopub.execute_input":"2026-04-07T09:11:20.210823Z","iopub.status.busy":"2026-04-07T09:11:20.210581Z","iopub.status.idle":"2026-04-07T09:11:20.218725Z","shell.execute_reply":"2026-04-07T09:11:20.218145Z"},"papermill":{"duration":0.014245,"end_time":"2026-04-07T09:11:20.220078","exception":false,"start_time":"2026-04-07T09:11:20.205833","status":"completed"},"tags":[]},"outputs":[],"source":["def normalize_binary_label(series: pd.Series) -> pd.Series:\n","    '''\n","    Konversi label Brugada menjadi biner:\n","    - original Brugada-HUCA: 0 = normal, >0 = positif\n","    - synthetic: diasumsikan sudah 0/1 atau bisa dipaksa menjadi >0\n","    '''\n","    s = pd.to_numeric(series, errors=\"coerce\").fillna(0)\n","    return (s > 0).astype(int)\n","\n","def load_original_metadata(config: dict) -> pd.DataFrame:\n","    df = pd.read_csv(config[\"original_metadata_path\"])\n","    id_col = config[\"id_col\"]\n","    label_col = config[\"label_col_original\"]\n","    if id_col not in df.columns:\n","        raise KeyError(f\"Kolom '{id_col}' tidak ditemukan di metadata original.\")\n","    if label_col not in df.columns:\n","        raise KeyError(f\"Kolom '{label_col}' tidak ditemukan di metadata original.\")\n","    df = df.copy()\n","    df[\"label\"] = normalize_binary_label(df[label_col])\n","    df[\"source\"] = \"original\"\n","    return df\n","\n","def load_synthetic_metadata(config: dict) -> pd.DataFrame:\n","    df = pd.read_csv(config[\"synthetic_metadata_path\"])\n","    label_col = config[\"label_col_synthetic\"]\n","    if label_col not in df.columns:\n","        raise KeyError(f\"Kolom '{label_col}' tidak ditemukan di metadata synthetic.\")\n","    df = df.copy()\n","    if config[\"id_col\"] not in df.columns:\n","        # fallback sederhana\n","        if \"record_id\" in df.columns:\n","            df[config[\"id_col\"]] = df[\"record_id\"]\n","        else:\n","            df[config[\"id_col\"]] = np.arange(len(df)).astype(str)\n","    df[\"label\"] = normalize_binary_label(df[label_col])\n","    df[\"source\"] = \"synthetic\"\n","    return df\n","\n","def show_class_balance(df: pd.DataFrame, name: str = \"dataset\"):\n","    out = (\n","        df[\"label\"]\n","        .value_counts(dropna=False)\n","        .rename_axis(\"label\")\n","        .reset_index(name=\"count\")\n","        .sort_values(\"label\")\n","    )\n","    out[\"ratio\"] = out[\"count\"] / len(df)\n","    print(f\"\\n{name} | n={len(df)}\")\n","    display(out)"]},{"cell_type":"markdown","id":"ecce13a6","metadata":{"papermill":{"duration":0.003961,"end_time":"2026-04-07T09:11:20.227981","exception":false,"start_time":"2026-04-07T09:11:20.22402","status":"completed"},"tags":[]},"source":["## 3. Scenario Split\n","\n","Interpretasi yang dipakai agar konsisten secara matematis:\n","\n","### Synthetic-data scenario\n","1. Ambil **363 sampel sintesis** sebagai **test set**\n","2. Sisa data sintesis menjadi **development pool**\n","3. Development pool dibagi dengan rasio **90 : 5**\n","   - train = 90/95 dari dev pool\n","   - validation = 5/95 dari dev pool\n","\n","### Original-data scenario\n","1. Original data dibagi **95% train** dan **5% validation**\n","2. Test memakai **363 sampel sintesis** yang sama sebagai **external test set**"]},{"cell_type":"code","execution_count":6,"id":"94ce950b","metadata":{"execution":{"iopub.execute_input":"2026-04-07T09:11:20.237021Z","iopub.status.busy":"2026-04-07T09:11:20.236791Z","iopub.status.idle":"2026-04-07T09:11:20.24536Z","shell.execute_reply":"2026-04-07T09:11:20.244708Z"},"papermill":{"duration":0.015113,"end_time":"2026-04-07T09:11:20.246914","exception":false,"start_time":"2026-04-07T09:11:20.231801","status":"completed"},"tags":[]},"outputs":[],"source":["@dataclass\n","class ScenarioSplit:\n","    train_df: pd.DataFrame\n","    val_df: pd.DataFrame\n","    test_df: pd.DataFrame\n","\n","def make_synthetic_scenario_split(df_syn: pd.DataFrame, config: dict) -> ScenarioSplit:\n","    test_count = int(config[\"synthetic_test_count\"])\n","    if len(df_syn) <= test_count:\n","        raise ValueError(\n","            f\"Jumlah data sintesis ({len(df_syn)}) harus lebih besar dari synthetic_test_count ({test_count}).\"\n","        )\n","\n","    # 1) Hold-out fixed synthetic test set (363 sampel)\n","    dev_df, test_df = train_test_split(\n","        df_syn,\n","        test_size=test_count,\n","        stratify=df_syn[\"label\"],\n","        random_state=SEED,\n","    )\n","\n","    # 2) Split sisa dev menjadi train dan val dengan rasio 90:5\n","    train_ratio = config[\"synthetic_dev_train_ratio\"]\n","    val_ratio = config[\"synthetic_dev_val_ratio\"]\n","    val_fraction_within_dev = val_ratio / (train_ratio + val_ratio)\n","\n","    train_df, val_df = train_test_split(\n","        dev_df,\n","        test_size=val_fraction_within_dev,\n","        stratify=dev_df[\"label\"],\n","        random_state=SEED,\n","    )\n","\n","    return ScenarioSplit(\n","        train_df=train_df.reset_index(drop=True),\n","        val_df=val_df.reset_index(drop=True),\n","        test_df=test_df.reset_index(drop=True),\n","    )\n","\n","def make_original_scenario_split(df_org: pd.DataFrame, synthetic_test_df: pd.DataFrame, config: dict) -> ScenarioSplit:\n","    train_df, val_df = train_test_split(\n","        df_org,\n","        test_size=config[\"original_val_ratio\"],\n","        stratify=df_org[\"label\"],\n","        random_state=SEED,\n","    )\n","\n","    return ScenarioSplit(\n","        train_df=train_df.reset_index(drop=True),\n","        val_df=val_df.reset_index(drop=True),\n","        test_df=synthetic_test_df.reset_index(drop=True),\n","    )\n","\n","def summarize_split(split: ScenarioSplit, title: str):\n","    print(f\"\\n===== {title} =====\")\n","    for name, part in [(\"train\", split.train_df), (\"val\", split.val_df), (\"test\", split.test_df)]:\n","        counts = part[\"label\"].value_counts().sort_index().to_dict()\n","        print(f\"{name:>5}: n={len(part):>5} | class_counts={counts}\")"]},{"cell_type":"markdown","id":"f377456d","metadata":{"papermill":{"duration":0.00374,"end_time":"2026-04-07T09:11:20.254448","exception":false,"start_time":"2026-04-07T09:11:20.250708","status":"completed"},"tags":[]},"source":["## 4. ECG Loading dan Median Beat\n","\n","Notebook ini mempertahankan pendekatan:\n","- preprocessing sinyal\n","- ekstraksi **median beat**\n","- dua representasi:\n","  - **feature-based** dari median beat\n","  - **sequence-based** dari median beat"]},{"cell_type":"code","execution_count":7,"id":"af25bd27","metadata":{"execution":{"iopub.execute_input":"2026-04-07T09:11:20.263387Z","iopub.status.busy":"2026-04-07T09:11:20.263098Z","iopub.status.idle":"2026-04-07T09:11:20.277873Z","shell.execute_reply":"2026-04-07T09:11:20.277324Z"},"papermill":{"duration":0.020971,"end_time":"2026-04-07T09:11:20.279282","exception":false,"start_time":"2026-04-07T09:11:20.258311","status":"completed"},"tags":[]},"outputs":[],"source":["LEAD_NAMES = [\"I\",\"II\",\"III\",\"aVR\",\"aVL\",\"aVF\",\"V1\",\"V2\",\"V3\",\"V4\",\"V5\",\"V6\"]\n","\n","def butter_bandpass_filter(x: np.ndarray, fs: int, low=0.5, high=40.0, order=4) -> np.ndarray:\n","    nyq = 0.5 * fs\n","    b, a = signal.butter(order, [low/nyq, high/nyq], btype=\"band\")\n","    return signal.filtfilt(b, a, x)\n","\n","def preprocess_ecg(sig: np.ndarray, fs: int) -> np.ndarray:\n","    # expected shape: (n_samples, n_leads) or (n_leads, n_samples)\n","    sig = np.asarray(sig, dtype=np.float32)\n","    if sig.ndim != 2:\n","        raise ValueError(f\"Signal harus 2D, dapat shape={sig.shape}\")\n","    if sig.shape[0] == len(LEAD_NAMES) and sig.shape[1] != len(LEAD_NAMES):\n","        sig = sig.T  # to (n_samples, n_leads)\n","    if sig.shape[1] != len(LEAD_NAMES):\n","        raise ValueError(f\"Jumlah lead tidak cocok. Shape setelah normalisasi: {sig.shape}\")\n","\n","    out = np.zeros_like(sig, dtype=np.float32)\n","    for i in range(sig.shape[1]):\n","        xi = sig[:, i]\n","        xf = butter_bandpass_filter(xi, fs=fs)\n","        x_min, x_max = xf.min(), xf.max()\n","        if x_max - x_min < 1e-8:\n","            out[:, i] = 0.0\n","        else:\n","            out[:, i] = (xf - x_min) / (x_max - x_min)\n","    return out\n","\n","def detect_r_peaks(ecg_1lead: np.ndarray, fs: int, min_peak_distance_sec: float = 0.45) -> np.ndarray:\n","    distance = max(1, int(fs * min_peak_distance_sec))\n","    # deteksi sederhana: prominence menyesuaikan sinyal\n","    prominence = max(0.05, np.std(ecg_1lead) * 0.5)\n","    peaks, _ = signal.find_peaks(ecg_1lead, distance=distance, prominence=prominence)\n","    return peaks\n","\n","def extract_median_beat(sig: np.ndarray, fs: int, peak_lead: int, pre_r_sec: float, post_r_sec: float) -> np.ndarray:\n","    '''\n","    Input  : sig shape (n_samples, n_leads), sudah dipreprocess\n","    Output : median beat shape (beat_len, n_leads)\n","    '''\n","    ecg_lead = sig[:, peak_lead]\n","    peaks = detect_r_peaks(ecg_lead, fs=fs, min_peak_distance_sec=CONFIG[\"min_peak_distance_sec\"])\n","\n","    pre = int(pre_r_sec * fs)\n","    post = int(post_r_sec * fs)\n","    beat_len = pre + post\n","\n","    segments = []\n","    for p in peaks:\n","        s = p - pre\n","        e = p + post\n","        if s >= 0 and e <= len(sig):\n","            segments.append(sig[s:e, :])\n","\n","    if len(segments) == 0:\n","        # fallback: ambil potongan tengah\n","        center = len(sig) // 2\n","        s = max(0, center - pre)\n","        e = min(len(sig), center + post)\n","        seg = sig[s:e, :]\n","        if len(seg) < beat_len:\n","            pad = np.zeros((beat_len - len(seg), sig.shape[1]), dtype=np.float32)\n","            seg = np.vstack([seg, pad])\n","        return seg.astype(np.float32)\n","\n","    stacked = np.stack(segments, axis=0)  # (n_beats, beat_len, n_leads)\n","    median_beat = np.median(stacked, axis=0)\n","    return median_beat.astype(np.float32)\n","\n","def load_original_signal(record_id: str, config: dict) -> np.ndarray:\n","    if wfdb is None:\n","        raise ImportError(\"wfdb belum tersedia.\")\n","    record_id = str(record_id)\n","    rec_path = os.path.join(config[\"original_records_root\"], record_id, record_id)\n","    record = wfdb.rdrecord(rec_path)\n","    sig = record.p_signal  # (n_samples, n_leads)\n","    return sig.astype(np.float32)\n","\n","def load_synthetic_signal(row: pd.Series, config: dict) -> np.ndarray:\n","    '''\n","    Loader generik.\n","    Dukungan default:\n","    - kolom path relatif ke file .npy / .npz\n","    - atau folder WFDB bila Anda menambahkan logika sendiri\n","    '''\n","    base = config[\"synthetic_records_root\"]\n","\n","    if \"signal_path\" in row.index:\n","        fp = os.path.join(base, str(row[\"signal_path\"]))\n","        if fp.endswith(\".npy\"):\n","            return np.load(fp).astype(np.float32)\n","        elif fp.endswith(\".npz\"):\n","            z = np.load(fp)\n","            key = list(z.keys())[0]\n","            return z[key].astype(np.float32)\n","        else:\n","            raise ValueError(f\"Format synthetic signal belum didukung otomatis: {fp}\")\n","\n","    # fallback: coba {id}.npy\n","    fp = os.path.join(base, f\"{row[config['id_col']]}.npy\")\n","    if os.path.exists(fp):\n","        return np.load(fp).astype(np.float32)\n","\n","    raise FileNotFoundError(\n","        \"Tidak menemukan file sinyal synthetic. Tambahkan kolom `signal_path` \"\n","        \"atau sesuaikan fungsi load_synthetic_signal().\"\n","    )"]},{"cell_type":"markdown","id":"f03efe1b","metadata":{"papermill":{"duration":0.003892,"end_time":"2026-04-07T09:11:20.287127","exception":false,"start_time":"2026-04-07T09:11:20.283235","status":"completed"},"tags":[]},"source":["## 5. Feature-based Representation dari Median Beat\n","\n","Fitur tetap dibangun dari **median beat**, bukan dari sinyal penuh."]},{"cell_type":"code","execution_count":8,"id":"2ef967cc","metadata":{"execution":{"iopub.execute_input":"2026-04-07T09:11:20.296542Z","iopub.status.busy":"2026-04-07T09:11:20.296128Z","iopub.status.idle":"2026-04-07T09:11:20.304535Z","shell.execute_reply":"2026-04-07T09:11:20.303909Z"},"papermill":{"duration":0.015075,"end_time":"2026-04-07T09:11:20.30599","exception":false,"start_time":"2026-04-07T09:11:20.290915","status":"completed"},"tags":[]},"outputs":[],"source":["def summarize_vector(x: np.ndarray, prefix: str) -> Dict[str, float]:\n","    return {\n","        f\"{prefix}_mean\": float(np.mean(x)),\n","        f\"{prefix}_std\": float(np.std(x)),\n","        f\"{prefix}_min\": float(np.min(x)),\n","        f\"{prefix}_max\": float(np.max(x)),\n","        f\"{prefix}_ptp\": float(np.ptp(x)),\n","        f\"{prefix}_median\": float(np.median(x)),\n","        f\"{prefix}_energy\": float(np.sum(np.square(x))),\n","    }\n","\n","def extract_feature_based_representation(median_beat: np.ndarray) -> Dict[str, float]:\n","    '''\n","    median_beat shape: (beat_len, n_leads)\n","    Feature engineering ringan tetapi tetap berbasis median beat.\n","    '''\n","    feats = {}\n","    beat_len, n_leads = median_beat.shape\n","\n","    for lead_idx in range(n_leads):\n","        x = median_beat[:, lead_idx]\n","        lead_name = LEAD_NAMES[lead_idx]\n","\n","        feats.update(summarize_vector(x, f\"{lead_name}\"))\n","\n","        # turunan pertama\n","        dx = np.diff(x, prepend=x[0])\n","        feats.update(summarize_vector(dx, f\"{lead_name}_dx\"))\n","\n","        # area global\n","        feats[f\"{lead_name}_auc\"] = float(np.trapz(x))\n","        feats[f\"{lead_name}_abs_auc\"] = float(np.trapz(np.abs(x)))\n","\n","        # landmark sederhana relatif terhadap puncak R\n","        r_idx = int(np.argmax(x))\n","        feats[f\"{lead_name}_r_amp\"] = float(x[r_idx])\n","        feats[f\"{lead_name}_r_idx\"] = float(r_idx)\n","\n","        # window sesudah R sebagai proksi ST\n","        st_start = min(r_idx + 4, beat_len - 2)\n","        st_end = min(r_idx + 12, beat_len - 1)\n","        st_seg = x[st_start:st_end]\n","        if len(st_seg) > 1:\n","            feats[f\"{lead_name}_st_mean\"] = float(np.mean(st_seg))\n","            feats[f\"{lead_name}_st_slope\"] = float((st_seg[-1] - st_seg[0]) / len(st_seg))\n","        else:\n","            feats[f\"{lead_name}_st_mean\"] = 0.0\n","            feats[f\"{lead_name}_st_slope\"] = 0.0\n","\n","    # fitur lintas lead yang relevan untuk Brugada\n","    right_precordial = [LEAD_NAMES.index(\"V1\"), LEAD_NAMES.index(\"V2\"), LEAD_NAMES.index(\"V3\")]\n","    for li in right_precordial:\n","        x = median_beat[:, li]\n","        feats[f\"{LEAD_NAMES[li]}_top3_mean\"] = float(np.mean(np.sort(x)[-3:]))\n","\n","    return feats"]},{"cell_type":"markdown","id":"25de8faf","metadata":{"papermill":{"duration":0.003818,"end_time":"2026-04-07T09:11:20.313664","exception":false,"start_time":"2026-04-07T09:11:20.309846","status":"completed"},"tags":[]},"source":["## 6. Sequence-based Representation dari Median Beat\n","\n","Untuk branch sequence-based, input tetap berasal dari **median beat** berbentuk tensor:\n","- `(n_leads, beat_len)`"]},{"cell_type":"code","execution_count":9,"id":"86182a55","metadata":{"execution":{"iopub.execute_input":"2026-04-07T09:11:20.323309Z","iopub.status.busy":"2026-04-07T09:11:20.32262Z","iopub.status.idle":"2026-04-07T09:11:20.325975Z","shell.execute_reply":"2026-04-07T09:11:20.325484Z"},"papermill":{"duration":0.009564,"end_time":"2026-04-07T09:11:20.327326","exception":false,"start_time":"2026-04-07T09:11:20.317762","status":"completed"},"tags":[]},"outputs":[],"source":["def extract_sequence_based_representation(median_beat: np.ndarray) -> np.ndarray:\n","    # from (beat_len, n_leads) -> (n_leads, beat_len)\n","    return median_beat.T.astype(np.float32)"]},{"cell_type":"markdown","id":"d1c2a36b","metadata":{"papermill":{"duration":0.003832,"end_time":"2026-04-07T09:11:20.335045","exception":false,"start_time":"2026-04-07T09:11:20.331213","status":"completed"},"tags":[]},"source":["## 7. Build Table / Tensor dari DataFrame Split"]},{"cell_type":"code","execution_count":10,"id":"cabec0b8","metadata":{"execution":{"iopub.execute_input":"2026-04-07T09:11:20.344288Z","iopub.status.busy":"2026-04-07T09:11:20.343903Z","iopub.status.idle":"2026-04-07T09:11:20.349824Z","shell.execute_reply":"2026-04-07T09:11:20.349159Z"},"papermill":{"duration":0.01196,"end_time":"2026-04-07T09:11:20.351236","exception":false,"start_time":"2026-04-07T09:11:20.339276","status":"completed"},"tags":[]},"outputs":[],"source":["def build_representations(df: pd.DataFrame, source: str, config: dict):\n","    feature_rows = []\n","    sequence_rows = []\n","    labels = []\n","    ids = []\n","\n","    for _, row in df.iterrows():\n","        record_id = row[config[\"id_col\"]]\n","        if source == \"original\":\n","            sig = load_original_signal(record_id, config)\n","        elif source == \"synthetic\":\n","            sig = load_synthetic_signal(row, config)\n","        else:\n","            raise ValueError(f\"Source tidak dikenali: {source}\")\n","\n","        sig = preprocess_ecg(sig, fs=config[\"fs\"])\n","        med = extract_median_beat(\n","            sig=sig,\n","            fs=config[\"fs\"],\n","            peak_lead=config[\"peak_lead\"],\n","            pre_r_sec=config[\"median_pre_r\"],\n","            post_r_sec=config[\"median_post_r\"],\n","        )\n","\n","        feature_rows.append(extract_feature_based_representation(med))\n","        sequence_rows.append(extract_sequence_based_representation(med))\n","        labels.append(int(row[\"label\"]))\n","        ids.append(record_id)\n","\n","    X_feat = pd.DataFrame(feature_rows)\n","    X_seq = np.stack(sequence_rows, axis=0)  # (N, n_leads, beat_len)\n","    y = np.asarray(labels).astype(int)\n","\n","    return ids, X_feat, X_seq, y"]},{"cell_type":"markdown","id":"19307fee","metadata":{"papermill":{"duration":0.00418,"end_time":"2026-04-07T09:11:20.359563","exception":false,"start_time":"2026-04-07T09:11:20.355383","status":"completed"},"tags":[]},"source":["## 8. Model Registry — Feature-based\n","\n","Sesuai permintaan:\n","- XGBoost\n","- Random Forest\n","- SVM RBF\n","- AdaBoost"]},{"cell_type":"code","execution_count":11,"id":"cf844836","metadata":{"execution":{"iopub.execute_input":"2026-04-07T09:11:20.369264Z","iopub.status.busy":"2026-04-07T09:11:20.368802Z","iopub.status.idle":"2026-04-07T09:11:20.376439Z","shell.execute_reply":"2026-04-07T09:11:20.375749Z"},"papermill":{"duration":0.013828,"end_time":"2026-04-07T09:11:20.377842","exception":false,"start_time":"2026-04-07T09:11:20.364014","status":"completed"},"tags":[]},"outputs":[{"data":{"text/plain":["['XGBoost', 'Random Forest', 'SVM RBF', 'AdaBoost']"]},"execution_count":11,"metadata":{},"output_type":"execute_result"}],"source":["def build_feature_models(random_state: int = 42) -> Dict[str, object]:\n","    models = {}\n","\n","    if XGBClassifier is not None:\n","        models[\"XGBoost\"] = Pipeline([\n","            (\"scaler\", StandardScaler()),\n","            (\"clf\", XGBClassifier(\n","                n_estimators=300,\n","                max_depth=5,\n","                learning_rate=0.05,\n","                subsample=0.9,\n","                colsample_bytree=0.9,\n","                objective=\"binary:logistic\",\n","                eval_metric=\"logloss\",\n","                random_state=random_state,\n","            ))\n","        ])\n","\n","    models[\"Random Forest\"] = Pipeline([\n","        (\"clf\", RandomForestClassifier(\n","            n_estimators=400,\n","            max_depth=None,\n","            min_samples_split=4,\n","            min_samples_leaf=2,\n","            class_weight=\"balanced\",\n","            random_state=random_state,\n","            n_jobs=-1,\n","        ))\n","    ])\n","\n","    models[\"SVM RBF\"] = Pipeline([\n","        (\"scaler\", StandardScaler()),\n","        (\"clf\", SVC(\n","            kernel=\"rbf\",\n","            C=2.0,\n","            gamma=\"scale\",\n","            probability=True,\n","            class_weight=\"balanced\",\n","            random_state=random_state,\n","        ))\n","    ])\n","\n","    models[\"AdaBoost\"] = Pipeline([\n","        (\"clf\", AdaBoostClassifier(\n","            n_estimators=250,\n","            learning_rate=0.05,\n","            random_state=random_state,\n","        ))\n","    ])\n","\n","    return models\n","\n","FEATURE_MODELS = build_feature_models(SEED)\n","list(FEATURE_MODELS.keys())"]},{"cell_type":"markdown","id":"5084316d","metadata":{"papermill":{"duration":0.004657,"end_time":"2026-04-07T09:11:20.387043","exception":false,"start_time":"2026-04-07T09:11:20.382386","status":"completed"},"tags":[]},"source":["## 9. Model Registry — Sequence-based\n","\n","Sesuai permintaan:\n","- 1D CNN\n","- ResNet 1D\n","- CNN + BiGRU\n","- Transformer Encoder\n","\n","Tambahan advanced branch:\n","- Transfer Learning (DAE)\n","- VICReg\n","- ESN"]},{"cell_type":"code","execution_count":12,"id":"ea3f0dbe","metadata":{"execution":{"iopub.execute_input":"2026-04-07T09:11:20.397483Z","iopub.status.busy":"2026-04-07T09:11:20.397169Z","iopub.status.idle":"2026-04-07T09:11:20.416861Z","shell.execute_reply":"2026-04-07T09:11:20.416057Z"},"papermill":{"duration":0.026916,"end_time":"2026-04-07T09:11:20.418431","exception":false,"start_time":"2026-04-07T09:11:20.391515","status":"completed"},"tags":[]},"outputs":[],"source":["if torch is not None:\n","    class ECGDataset(Dataset):\n","        def __init__(self, X, y):\n","            self.X = torch.tensor(X, dtype=torch.float32)\n","            self.y = torch.tensor(y, dtype=torch.float32)\n","\n","        def __len__(self):\n","            return len(self.X)\n","\n","        def __getitem__(self, idx):\n","            return self.X[idx], self.y[idx]\n","\n","    class CNN1D(nn.Module):\n","        def __init__(self, n_leads=12, n_classes=1):\n","            super().__init__()\n","            self.features = nn.Sequential(\n","                nn.Conv1d(n_leads, 64, kernel_size=7, padding=3),\n","                nn.BatchNorm1d(64),\n","                nn.ReLU(),\n","                nn.MaxPool1d(2),\n","\n","                nn.Conv1d(64, 128, kernel_size=5, padding=2),\n","                nn.BatchNorm1d(128),\n","                nn.ReLU(),\n","                nn.MaxPool1d(2),\n","\n","                nn.Conv1d(128, 256, kernel_size=3, padding=1),\n","                nn.BatchNorm1d(256),\n","                nn.ReLU(),\n","                nn.AdaptiveAvgPool1d(1),\n","            )\n","            self.classifier = nn.Sequential(\n","                nn.Flatten(),\n","                nn.Linear(256, 128),\n","                nn.ReLU(),\n","                nn.Dropout(0.3),\n","                nn.Linear(128, n_classes),\n","            )\n","\n","        def forward(self, x):\n","            x = self.features(x)\n","            return self.classifier(x).squeeze(-1)\n","\n","    class ResidualBlock1D(nn.Module):\n","        def __init__(self, in_ch, out_ch, stride=1):\n","            super().__init__()\n","            self.conv1 = nn.Conv1d(in_ch, out_ch, 3, stride=stride, padding=1)\n","            self.bn1 = nn.BatchNorm1d(out_ch)\n","            self.conv2 = nn.Conv1d(out_ch, out_ch, 3, padding=1)\n","            self.bn2 = nn.BatchNorm1d(out_ch)\n","\n","            if stride != 1 or in_ch != out_ch:\n","                self.shortcut = nn.Sequential(\n","                    nn.Conv1d(in_ch, out_ch, 1, stride=stride),\n","                    nn.BatchNorm1d(out_ch)\n","                )\n","            else:\n","                self.shortcut = nn.Identity()\n","\n","        def forward(self, x):\n","            residual = self.shortcut(x)\n","            x = torch.relu(self.bn1(self.conv1(x)))\n","            x = self.bn2(self.conv2(x))\n","            x = torch.relu(x + residual)\n","            return x\n","\n","    class ResNet1D(nn.Module):\n","        def __init__(self, n_leads=12, n_classes=1):\n","            super().__init__()\n","            self.stem = nn.Sequential(\n","                nn.Conv1d(n_leads, 64, kernel_size=7, padding=3),\n","                nn.BatchNorm1d(64),\n","                nn.ReLU(),\n","            )\n","            self.body = nn.Sequential(\n","                ResidualBlock1D(64, 64),\n","                ResidualBlock1D(64, 128, stride=2),\n","                ResidualBlock1D(128, 256, stride=2),\n","            )\n","            self.head = nn.Sequential(\n","                nn.AdaptiveAvgPool1d(1),\n","                nn.Flatten(),\n","                nn.Linear(256, 128),\n","                nn.ReLU(),\n","                nn.Dropout(0.3),\n","                nn.Linear(128, n_classes),\n","            )\n","\n","        def forward(self, x):\n","            x = self.stem(x)\n","            x = self.body(x)\n","            return self.head(x).squeeze(-1)\n","\n","    class CNNBiGRU(nn.Module):\n","        def __init__(self, n_leads=12, n_classes=1):\n","            super().__init__()\n","            self.conv = nn.Sequential(\n","                nn.Conv1d(n_leads, 64, kernel_size=5, padding=2),\n","                nn.BatchNorm1d(64),\n","                nn.ReLU(),\n","                nn.MaxPool1d(2),\n","                nn.Conv1d(64, 128, kernel_size=3, padding=1),\n","                nn.BatchNorm1d(128),\n","                nn.ReLU(),\n","            )\n","            self.bigru = nn.GRU(\n","                input_size=128,\n","                hidden_size=64,\n","                num_layers=1,\n","                batch_first=True,\n","                bidirectional=True,\n","            )\n","            self.fc = nn.Sequential(\n","                nn.Linear(128, 64),\n","                nn.ReLU(),\n","                nn.Dropout(0.3),\n","                nn.Linear(64, n_classes),\n","            )\n","\n","        def forward(self, x):\n","            x = self.conv(x)                # (B, C, T)\n","            x = x.transpose(1, 2)           # (B, T, C)\n","            x, _ = self.bigru(x)\n","            x = x.mean(dim=1)\n","            return self.fc(x).squeeze(-1)\n","\n","    class TransformerEncoderModel(nn.Module):\n","        def __init__(self, n_leads=12, seq_len=70, d_model=96, nhead=4, num_layers=2, n_classes=1):\n","            super().__init__()\n","            self.proj = nn.Conv1d(n_leads, d_model, kernel_size=1)\n","            encoder_layer = nn.TransformerEncoderLayer(\n","                d_model=d_model,\n","                nhead=nhead,\n","                batch_first=True,\n","                dim_feedforward=192,\n","                dropout=0.2,\n","                activation=\"gelu\",\n","            )\n","            self.encoder = nn.TransformerEncoder(encoder_layer, num_layers=num_layers)\n","            self.fc = nn.Sequential(\n","                nn.Linear(d_model, 64),\n","                nn.ReLU(),\n","                nn.Dropout(0.3),\n","                nn.Linear(64, n_classes),\n","            )\n","\n","        def forward(self, x):\n","            x = self.proj(x)        # (B, d_model, T)\n","            x = x.transpose(1, 2)   # (B, T, d_model)\n","            x = self.encoder(x)\n","            x = x.mean(dim=1)\n","            return self.fc(x).squeeze(-1)\n","\n","    # Advanced branch placeholders\n","    class DAETransferModel(nn.Module):\n","        def __init__(self, backbone: Optional[nn.Module] = None):\n","            super().__init__()\n","            self.backbone = backbone if backbone is not None else CNN1D()\n","\n","        def forward(self, x):\n","            return self.backbone(x)\n","\n","    class VICRegBackbone(nn.Module):\n","        def __init__(self):\n","            super().__init__()\n","            self.encoder = CNN1D()\n","\n","        def forward(self, x):\n","            return self.encoder(x)\n","\n","    class ESNWrapper:\n","        '''\n","        Placeholder untuk Echo State Network (ESN).\n","        Implementasi final biasanya memakai reservoir computing library khusus.\n","        '''\n","        def __init__(self):\n","            self.name = \"ESN\""]},{"cell_type":"code","execution_count":13,"id":"7ccb8474","metadata":{"execution":{"iopub.execute_input":"2026-04-07T09:11:20.428211Z","iopub.status.busy":"2026-04-07T09:11:20.427942Z","iopub.status.idle":"2026-04-07T09:11:20.548164Z","shell.execute_reply":"2026-04-07T09:11:20.547327Z"},"papermill":{"duration":0.127006,"end_time":"2026-04-07T09:11:20.549953","exception":false,"start_time":"2026-04-07T09:11:20.422947","status":"completed"},"tags":[]},"outputs":[{"data":{"text/plain":["['1D CNN',\n"," 'ResNet 1D',\n"," 'CNN + BiGRU',\n"," 'Transformer Encoder',\n"," 'Transfer Learning (DAE)',\n"," 'VICReg',\n"," 'ESN']"]},"execution_count":13,"metadata":{},"output_type":"execute_result"}],"source":["def build_sequence_models():\n","    if torch is None:\n","        return {}\n","\n","    # beat_len = pre_r + post_r = 0.25*100 + 0.45*100 = 70\n","    beat_len = int(CONFIG[\"median_pre_r\"] * CONFIG[\"fs\"] + CONFIG[\"median_post_r\"] * CONFIG[\"fs\"])\n","\n","    return {\n","        \"1D CNN\": CNN1D(n_leads=CONFIG[\"n_leads\"]),\n","        \"ResNet 1D\": ResNet1D(n_leads=CONFIG[\"n_leads\"]),\n","        \"CNN + BiGRU\": CNNBiGRU(n_leads=CONFIG[\"n_leads\"]),\n","        \"Transformer Encoder\": TransformerEncoderModel(n_leads=CONFIG[\"n_leads\"], seq_len=beat_len),\n","        \"Transfer Learning (DAE)\": DAETransferModel(),\n","        \"VICReg\": VICRegBackbone(),\n","        \"ESN\": ESNWrapper(),\n","    }\n","\n","SEQUENCE_MODELS = build_sequence_models()\n","list(SEQUENCE_MODELS.keys()) if len(SEQUENCE_MODELS) else \"Torch belum tersedia\""]},{"cell_type":"markdown","id":"b67fa330","metadata":{"papermill":{"duration":0.005098,"end_time":"2026-04-07T09:11:20.560073","exception":false,"start_time":"2026-04-07T09:11:20.554975","status":"completed"},"tags":[]},"source":["## 10. Evaluasi Model Feature-based"]},{"cell_type":"code","execution_count":14,"id":"bbe485b4","metadata":{"execution":{"iopub.execute_input":"2026-04-07T09:11:20.571803Z","iopub.status.busy":"2026-04-07T09:11:20.571256Z","iopub.status.idle":"2026-04-07T09:11:20.580119Z","shell.execute_reply":"2026-04-07T09:11:20.579269Z"},"papermill":{"duration":0.016774,"end_time":"2026-04-07T09:11:20.581784","exception":false,"start_time":"2026-04-07T09:11:20.56501","status":"completed"},"tags":[]},"outputs":[],"source":["def compute_metrics(y_true, y_prob, threshold=0.5):\n","    y_pred = (y_prob >= threshold).astype(int)\n","    return {\n","        \"accuracy\": accuracy_score(y_true, y_pred),\n","        \"precision\": precision_score(y_true, y_pred, zero_division=0),\n","        \"recall\": recall_score(y_true, y_pred, zero_division=0),\n","        \"f1\": f1_score(y_true, y_pred, zero_division=0),\n","        \"auc\": roc_auc_score(y_true, y_prob) if len(np.unique(y_true)) > 1 else np.nan,\n","    }\n","\n","def get_prob_from_estimator(model, X):\n","    if hasattr(model, \"predict_proba\"):\n","        return model.predict_proba(X)[:, 1]\n","    if hasattr(model, \"decision_function\"):\n","        z = model.decision_function(X)\n","        z = (z - z.min()) / (z.max() - z.min() + 1e-8)\n","        return z\n","    return model.predict(X)\n","\n","def train_and_evaluate_feature_models(X_train, y_train, X_val, y_val, X_test, y_test):\n","    rows = []\n","    fitted_models = {}\n","\n","    for name, model in FEATURE_MODELS.items():\n","        print(f\"Training feature model: {name}\")\n","        mdl = clone(model)\n","        mdl.fit(X_train, y_train)\n","\n","        val_prob = get_prob_from_estimator(mdl, X_val)\n","        test_prob = get_prob_from_estimator(mdl, X_test)\n","\n","        val_metrics = compute_metrics(y_val, val_prob)\n","        test_metrics = compute_metrics(y_test, test_prob)\n","\n","        rows.append({\n","            \"model\": name,\n","            \"val_f1\": val_metrics[\"f1\"],\n","            \"val_recall\": val_metrics[\"recall\"],\n","            \"val_auc\": val_metrics[\"auc\"],\n","            \"test_f1\": test_metrics[\"f1\"],\n","            \"test_recall\": test_metrics[\"recall\"],\n","            \"test_auc\": test_metrics[\"auc\"],\n","        })\n","        fitted_models[name] = mdl\n","\n","    return pd.DataFrame(rows).sort_values([\"test_f1\", \"test_auc\"], ascending=False), fitted_models"]},{"cell_type":"markdown","id":"1a5fee37","metadata":{"papermill":{"duration":0.00469,"end_time":"2026-04-07T09:11:20.591836","exception":false,"start_time":"2026-04-07T09:11:20.587146","status":"completed"},"tags":[]},"source":["## 11. Runner untuk Membentuk Scenario Split\n","\n","Cell ini hanya membentuk split. Jalankan setelah Anda memastikan path original dan synthetic sudah benar."]},{"cell_type":"code","execution_count":15,"id":"b4a4145d","metadata":{"execution":{"iopub.execute_input":"2026-04-07T09:11:20.60333Z","iopub.status.busy":"2026-04-07T09:11:20.602686Z","iopub.status.idle":"2026-04-07T09:11:20.606602Z","shell.execute_reply":"2026-04-07T09:11:20.605828Z"},"papermill":{"duration":0.0